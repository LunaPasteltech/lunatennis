---
import { t, type Locale, GALLERY_IMAGES } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).gallery;
const B = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section class="gal pad" id="gallery">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
    </div>

    <div class="grid reveal">
      {GALLERY_IMAGES.map((src, i) =>
        src ? (
          <figure class={`cell c${i + 1}`}>
            <img src={`${B}${src}`} alt="" loading="lazy" data-lightbox />
          </figure>
        ) : (
          <figure class={`cell c${i + 1} empty`}><span>{c.slot}</span></figure>
        )
      )}
    </div>
  </div>

  <!-- lightbox -->
  <div class="lb" id="lb" aria-hidden="true">
    <button class="lb-close" aria-label="Close">×</button>
    <img alt="" />
  </div>
</section>

<style>
  .gal { background: var(--paper); }
  .grid {
    margin-top: 50px;
    display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 210px; gap: 14px;
  }
  .cell { margin: 0; overflow: hidden; border-radius: 4px; background: linear-gradient(160deg, var(--sand), var(--sand-deep)); position: relative; }
  .cell img { width: 100%; height: 100%; object-fit: cover; display: block; cursor: zoom-in; transition: transform 1s cubic-bezier(.16,1,.3,1); filter: saturate(1.03) contrast(1.01); }
  .cell:hover img { transform: scale(1.045); }
  /* editorial mosaic: a couple of larger cells for rhythm */
  .c1 { grid-column: span 2; grid-row: span 2; }
  .c4 { grid-row: span 2; }
  .empty { display: flex; align-items: center; justify-content: center; border: 1px dashed var(--sand-deep); }
  .empty span { font-size: .64rem; letter-spacing: .24em; text-transform: uppercase; color: var(--ink-soft); opacity: .7; }
  @media (max-width: 820px) {
    .grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 180px; }
    .c1 { grid-column: span 2; grid-row: span 2; }
  }

  /* lightbox */
  .lb { position: fixed; inset: 0; z-index: 300; background: rgba(20, 24, 20, .93); display: none; align-items: center; justify-content: center; padding: 4vmin; }
  .lb.open { display: flex; }
  .lb img { max-width: 92vw; max-height: 90vh; border-radius: 4px; box-shadow: 0 40px 120px -30px rgba(0,0,0,.8); }
  .lb-close { position: absolute; top: 18px; right: 26px; background: none; border: 0; color: rgba(251,248,241,.85); font-size: 42px; line-height: 1; cursor: pointer; font-family: var(--serif); }
  .lb-close:hover { color: #fff; }
</style>

<script>
  const lb = document.getElementById('lb') as HTMLElement;
  const lbImg = lb?.querySelector('img') as HTMLImageElement;
  document.querySelectorAll('[data-lightbox]').forEach((el) => {
    el.addEventListener('click', () => {
      lbImg.src = (el as HTMLImageElement).src;
      lb.classList.add('open');
      lb.setAttribute('aria-hidden', 'false');
    });
  });
  const close = () => { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); };
  lb?.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>
