---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).mentors;
const B = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section class="pad" id="mentors">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
    </div>

    <div class="people">
      {c.people.map((p) => (
        <article class="person reveal">
          <div class="photo breathe">
            {'photo' in p && p.photo
              ? <img src={`${B}${p.photo}`} alt={`${p.name} — ${p.role}`} loading="lazy" />
              : <span class="slot">{p.photoSlot}</span>}
          </div>
          <div class="info">
            <h3>{p.name}</h3>
            <p class="role">{p.role}</p>
            <ul class="facts">{p.facts.map((f) => <li>{f}</li>)}</ul>
            <p class="bio">{p.bio}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .people { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 54px; }
  @media (max-width: 820px) { .people { grid-template-columns: 1fr; } }
  .person { display: grid; grid-template-columns: 150px 1fr; gap: 24px; background: var(--paper); border: 1px solid var(--line); border-radius: 4px; padding: 28px; }
  @media (max-width: 480px) { .person { grid-template-columns: 1fr; } }
  .photo { aspect-ratio: 4/5; background: linear-gradient(160deg, var(--sand), var(--sand-deep)); border-radius: 3px; display: flex; align-items: flex-end; overflow: hidden; }
  .photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; }
  .slot { font-size: .54rem; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-soft); margin: 8px; padding: 4px 6px; border: 1px dashed var(--sand-deep); border-radius: 2px; background: rgba(255,255,255,.4); }
  .info h3 { font-size: 1.7rem; }
  .role { color: var(--terracotta); font-size: .82rem; letter-spacing: .04em; margin-top: 4px; }
  .facts { list-style: none; display: flex; flex-wrap: wrap; gap: 7px; margin: 16px 0; }
  .facts li { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-soft); border: 1px solid var(--line); border-radius: 30px; padding: 5px 12px; }
  .bio { font-size: .95rem; }
</style>
