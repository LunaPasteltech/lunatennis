---
import { t, type Locale } from '../i18n/content';
interface Props { locale: Locale }
const { locale } = Astro.props;
const tr = t(locale);
const B = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // guarantee trailing slash
const brandHref = locale === 'ru' ? B : `${B}${locale}/`;
const langs: { code: Locale; href: string; label: string }[] = [
  { code: 'ru', href: B, label: 'RU' },
  { code: 'es', href: `${B}es/`, label: 'ES' },
  { code: 'en', href: `${B}en/`, label: 'EN' },
];
---
<nav id="nav">
  <a class="brand" href={brandHref} aria-label="Luna — Tennis Retreat">
    <svg class="mark" viewBox="0 0 32 32" aria-hidden="true">
      <circle cx="16" cy="16" r="15" fill="#B5613A"/>
      <g fill="none" stroke="#FBF8F1" stroke-width="2" stroke-linecap="round" opacity="0.92">
        <path d="M5.5 5.5 C 12 11, 12 21, 5.5 26.5"/>
        <path d="M26.5 5.5 C 20 11, 20 21, 26.5 26.5"/>
      </g>
    </svg>
    <span class="btext">
      <span class="bname">{tr.nav.brand}</span>
      <span class="bsub">Tennis Retreat</span>
    </span>
  </a>

  <div class="links">
    {tr.nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>

  <div class="right">
    <div class="langs">
      {langs.map((l) => <a href={l.href} class={l.code === locale ? 'on' : ''}>{l.label}</a>)}
    </div>
    <a class="navcta" href="#apply">{tr.nav.cta}</a>
  </div>
</nav>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px clamp(20px, 4vw, 44px);
    transition: background .5s ease, box-shadow .5s ease, padding .5s ease;
  }
  nav.solid {
    background: rgba(251, 248, 241, .9);
    backdrop-filter: saturate(140%) blur(14px);
    box-shadow: 0 1px 0 var(--line);
    padding: 12px clamp(20px, 4vw, 44px);
  }
  .brand { display: flex; align-items: center; gap: 11px; }
  .mark { width: 34px; height: 34px; flex: none; filter: drop-shadow(0 1px 6px rgba(0,0,0,.18)); }
  .btext { display: flex; flex-direction: column; line-height: 1; }
  .bname {
    font-family: var(--serif); font-size: 1.35rem; font-weight: 600;
    letter-spacing: .14em; color: #fff; text-transform: none;
  }
  .bsub {
    margin-top: 4px;
    font-family: var(--sans); font-size: .5rem; font-weight: 500;
    letter-spacing: .34em; text-transform: uppercase; color: var(--terracotta-soft);
    white-space: nowrap;
  }
  nav.solid .bname { color: var(--ink); }
  nav.solid .bsub { color: var(--terracotta); }
  .links { display: flex; gap: 26px; }
  .links a, .langs a {
    font-family: var(--sans); font-size: .7rem; font-weight: 500;
    letter-spacing: .2em; text-transform: uppercase; color: #fff; opacity: .85;
    transition: opacity .3s, color .3s;
  }
  nav.solid .links a, nav.solid .langs a { color: var(--ink); }
  .links a:hover, .langs a:hover { opacity: 1; }
  .right { display: flex; align-items: center; gap: 22px; }
  .langs { display: flex; gap: 12px; }
  .langs a { opacity: .6; }
  .langs a.on { opacity: 1; color: var(--terracotta); }
  nav.solid .langs a.on { color: var(--terracotta); }
  .navcta {
    font-family: var(--sans); font-size: .68rem; font-weight: 500;
    letter-spacing: .2em; text-transform: uppercase; color: #fff;
    border: 1px solid rgba(255,255,255,.6); padding: 9px 20px; border-radius: 2px;
    transition: .4s;
  }
  nav.solid .navcta { color: var(--ink); border-color: var(--ink); }
  .navcta:hover { background: var(--terracotta); color: #fff; border-color: var(--terracotta); }
  @media (max-width: 920px) { .links { display: none; } }
  @media (max-width: 600px) { .navcta { display: none; } .right { gap: 0; } .mark { width: 30px; height: 30px; } .bname { font-size: 1.2rem; } }
</style>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('solid', window.scrollY > window.innerHeight * 0.7);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
