---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).pricing;
---
<section class="pricing pad" id="pricing">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
    </div>

    <div class="tiers reveal">
      {c.retreats.map((r) => (
        <div class={`tier ${r.early ? 'early' : ''}`}>
          <span class="tlabel">{r.label}</span>
          <span class="tdates">{r.dates}</span>
          <p class="price">{r.priceOld && <s>{r.priceOld}</s>} <b>{r.price}</b></p>
          <p class="pnote">{r.note}</p>
        </div>
      ))}
    </div>

    <p class="pairline reveal">{c.pairNote}</p>

    <ul class="lines reveal">{c.lines.map((l) => <li>{l}</li>)}</ul>

    <div class="cols reveal">
      <div class="col inc">
        <h3>{c.includedTitle}</h3>
        <ul>{c.included.map((i) => <li>{i}</li>)}</ul>
      </div>
      <div class="col exc">
        <h3>{c.notIncludedTitle}</h3>
        <ul>{c.notIncluded.map((i) => <li>{i}</li>)}</ul>
      </div>
    </div>

    <div class="center reveal"><a class="btn fill" href="#apply">{c.cta}</a></div>
  </div>
</section>

<style>
  .pricing { background: var(--paper); }

  .tiers { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(20px, 3vw, 32px); max-width: 760px; margin: 34px auto 0; align-items: stretch; }
  @media (max-width: 640px) { .tiers { grid-template-columns: 1fr; } }
  .tier { background: var(--ivory); border: 1px solid var(--line); border-radius: 4px; padding: clamp(26px, 3vw, 36px) clamp(22px, 3vw, 30px); text-align: center; }
  .tier.early { border-color: var(--terracotta); box-shadow: 0 10px 40px -18px rgba(181,97,58,.5); }
  .tlabel { font-family: var(--sans); font-size: .72rem; font-weight: 600; letter-spacing: .24em; text-transform: uppercase; color: var(--ink-soft); }
  .tier.early .tlabel { color: var(--terracotta); }
  .tdates { display: block; margin-top: 6px; font-family: var(--serif); font-size: 1.15rem; color: var(--ink); }

  .price { margin-top: 14px; font-family: var(--serif); }
  .price s { color: var(--ink-soft); opacity: .65; font-size: 1.4rem; margin-right: 8px; }
  .price b { font-size: clamp(2.1rem, 4.4vw, 3rem); font-weight: 500; color: var(--ink); }
  .tier.early .price b { color: var(--terracotta); }

  .pnote { color: var(--ink-soft); font-style: italic; font-family: var(--serif); margin-top: 8px; font-size: .98rem; }
  .tier.early .pnote { color: var(--terracotta); font-style: normal; font-family: var(--sans); font-size: .8rem; letter-spacing: .04em; }

  .pairline { text-align: center; margin: 22px auto 0; font-family: var(--serif); font-style: italic; color: var(--ink-soft); font-size: 1.02rem; }

  .lines { list-style: none; margin: 26px auto 0; max-width: 620px; text-align: center; }
  .lines li { padding: 7px 0; color: var(--ink-soft); font-size: .95rem; }

  .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 48px 0; }
  @media (max-width: 720px) { .cols { grid-template-columns: 1fr; } }
  .col { background: var(--ivory); border: 1px solid var(--line); border-radius: 4px; padding: 30px 28px; }
  .col h3 { font-size: 1.4rem; margin-bottom: 16px; }
  .inc h3 { color: var(--olive); }
  .exc h3 { color: var(--ink-soft); }
  .col ul { list-style: none; }
  .col li { padding: 9px 0; border-top: 1px solid var(--line); font-size: .95rem; color: var(--ink); display: flex; gap: 10px; }
  .col li:first-child { border-top: 0; }
  .inc li::before { content: '✓'; color: var(--olive); }
  .exc li { color: var(--ink-soft); }
  .exc li::before { content: '·'; color: var(--ink-soft); }
</style>
