---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).reviews;
const B = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section class="revs pad" id="reviews">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
    </div>

    <div class="cards">
      {c.people.map((p) => (
        <a class="card reveal" href={p.url} target="_blank" rel="noopener" aria-label={`${p.name} — Instagram`}>
          <div class="head">
            <div class="avatar">
              {'photo' in p && p.photo
                ? <img src={`${B}${p.photo}`} alt={p.name} loading="lazy" />
                : <span class="slot">{p.photoSlot}</span>}
            </div>
            <div class="who">
              <span class="name">{p.name}</span>
              {p.role && <span class="role">{p.role}</span>}
            </div>
          </div>
          <p class="text">{p.text}</p>
          <span class="ig">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4.2"/>
              <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/>
            </svg>
            {p.handle}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .revs { background: var(--paper); }
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 54px; }
  @media (max-width: 880px) { .cards { grid-template-columns: 1fr; max-width: 560px; margin-left: auto; margin-right: auto; } }
  .card {
    display: flex; flex-direction: column;
    background: var(--ivory); border: 1px solid var(--line); border-radius: 4px;
    padding: 30px 28px; transition: .5s cubic-bezier(.16,1,.3,1);
  }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow); border-color: transparent; }
  .head { display: flex; align-items: center; gap: 16px; }
  .avatar {
    width: 62px; height: 62px; border-radius: 50%; flex: none; overflow: hidden;
    background: linear-gradient(160deg, var(--sand), var(--sand-deep));
    display: flex; align-items: center; justify-content: center;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .slot { font-size: .42rem; letter-spacing: .06em; text-transform: uppercase; color: var(--ink-soft); text-align: center; padding: 4px; }
  .who { display: flex; flex-direction: column; }
  .name { font-family: var(--serif); font-size: 1.35rem; color: var(--ink); line-height: 1.1; }
  .role { margin-top: 4px; font-size: .72rem; letter-spacing: .16em; text-transform: uppercase; color: var(--terracotta); }
  .text { margin-top: 20px; font-size: .98rem; color: var(--ink-soft); line-height: 1.65; flex: 1; }
  .ig {
    margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--line);
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .78rem; letter-spacing: .1em; color: var(--ink-soft);
    transition: color .3s;
  }
  .ig svg { width: 16px; height: 16px; }
  .card:hover .ig { color: var(--terracotta); }
</style>
