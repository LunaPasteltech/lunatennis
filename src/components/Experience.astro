---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).experience;
const B = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section class="exp pad" id="experience">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
    </div>

    <div class="cards">
      {c.cards.map((card) => (
        <article class="card reveal">
          <div class="ico">{card.icon}</div>
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </article>
      ))}
    </div>

    <article class="highlight reveal">
      <div class="hbg" aria-hidden="true" style={`background-image:url(${B}lagavina/lagavina-3.jpg)`}></div>
      <div class="htext">
        <span class="tag">{c.highlight.tag}</span>
        <h3>{c.highlight.title}</h3>
        <p>{c.highlight.text}</p>
      </div>
      <div class="hcollage reveal">
        <figure class="c-main breathe">
          <img src={`${B}lagavina/lagavina-4.jpg`} alt="Hostal de La Gavina — вилла у моря в S’Agaró" loading="lazy" />
        </figure>
        <figure class="c-side">
          <img src={`${B}lagavina/lagavina-5.jpg`} alt="Грунтовый корт La Gavina — вид строго сверху" loading="lazy" />
        </figure>
        <figure class="c-side">
          <img src={`${B}lagavina/court-blonde.jpg`} alt="На грунтовом корте среди сосен" loading="lazy" />
        </figure>
      </div>
    </article>
  </div>
</section>

<style>
  .exp { background: var(--paper); }
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 54px; }
  @media (max-width: 880px) { .cards { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cards { grid-template-columns: 1fr; } }
  .card { background: var(--ivory); border: 1px solid var(--line); border-radius: 4px; padding: 34px 28px; transition: .5s cubic-bezier(.16,1,.3,1); }
  .card:hover { transform: translateY(-6px); box-shadow: var(--shadow); border-color: transparent; }
  .card .ico { font-size: 1.7rem; line-height: 1; }
  .card h3 { margin: 18px 0 10px; font-size: 1.5rem; }
  .card p { font-size: .96rem; }
  .highlight {
    position: relative; margin-top: clamp(48px, 7vw, 80px);
    display: grid; grid-template-columns: 1fr minmax(380px, 540px);
    gap: clamp(32px, 5vw, 60px); align-items: center;
    color: var(--ivory);
    border-radius: 6px; padding: clamp(44px, 6vw, 72px) clamp(34px, 5vw, 54px); overflow: hidden;
  }
  /* quiet atmosphere: heavily blurred greenery, barely readable as texture (~15–20%) */
  .hbg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    filter: blur(26px) saturate(.8) brightness(.7);
    transform: scale(1.25); /* hide blur edges — background lives INSIDE the card */
  }
  /* deep BOTTLE-green wash (brand green, matches joint/apply) — photo is mood, not a second image */
  .hbg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(31,47,38,.9) 0%, rgba(47,74,58,.85) 55%, rgba(58,80,62,.82) 100%);
  }
  /* extra left darkening — text readability is priority one */
  .highlight::before {
    content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: linear-gradient(90deg, rgba(20,32,25,.6) 0%, rgba(20,32,25,.24) 45%, transparent 70%);
    border-radius: 6px;
  }
  /* gentle vignette, crisp card edge */
  .highlight::after { content: ''; position: absolute; inset: 0; box-shadow: inset 0 0 110px rgba(8,14,10,.38); pointer-events: none; border-radius: 6px; }
  .htext, .hcollage { position: relative; z-index: 2; }

  /* 3-photo collage — strict grid, magazine spread, no overlap */
  .hcollage { display: grid; grid-template-columns: 1.8fr 1fr; grid-auto-rows: 1fr; gap: 14px; } /* hero + entourage, not three equals */
  .hcollage figure { margin: 0; overflow: hidden; border-radius: 4px; box-shadow: 0 26px 60px -30px rgba(0,0,0,.6); }
  .hcollage img { width: 100%; height: 100%; object-fit: cover; display: block; filter: saturate(1.04) contrast(1.02) sepia(.05); } /* unified warm grade */
  .c-main { grid-row: span 2; }
  .c-main img { --breathe-max: 1.12; } /* the one moving element — slightly wider amplitude, same slow pace */
  .c-side { aspect-ratio: 3/4; } /* vertical slots — figure AND racket fit */
  .hcollage figure:last-child img { object-position: center bottom; } /* Natasha: keep the racket in frame */
  @media (max-width: 780px) {
    .highlight { grid-template-columns: 1fr; }
    .hcollage { grid-template-columns: 1fr 1fr; }
    .c-main { grid-column: span 2; grid-row: auto; aspect-ratio: 16/10; }
  }
  .highlight .tag { font-family: var(--sans); font-size: .68rem; letter-spacing: .3em; text-transform: uppercase; color: var(--brass); }
  .highlight h3 { color: var(--ivory); margin: 14px 0 12px; font-size: clamp(1.7rem, 3vw, 2.4rem); }
  .highlight p { color: rgba(251,248,241,.86); max-width: 52ch; }
  .hphoto { margin: 0; aspect-ratio: 4/5; overflow: hidden; border-radius: 4px; box-shadow: 0 32px 70px -34px rgba(0,0,0,.65); }
  .hphoto img { width: 100%; height: 100%; object-fit: cover; }
</style>
