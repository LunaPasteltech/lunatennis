---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).concept;
---
<section class="pad" id="concept">
  <div class="wrap center">
    <p class="eyebrow reveal">{c.eyebrow}</p>
    <div class="rule reveal"></div>
    <h2 class="reveal">{c.title}</h2>
    <p class="reveal body">{c.body}</p>
    <ul class="tags reveal">{c.tags.map((tag) => <li>{tag}</li>)}</ul>
    <p class="note reveal">{c.note}</p>
  </div>
</section>

<style>
  .body { max-width: 640px; margin: 22px auto 0; }
  .tags { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin: 36px auto 0; max-width: 760px; }
  .tags li { border: 1px solid var(--line); border-radius: 40px; padding: 9px 20px; font-size: .76rem; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-soft); }
  .note { font-family: var(--serif); font-style: italic; font-size: clamp(1.3rem, 2.4vw, 1.7rem); color: var(--ink); max-width: 620px; margin: 40px auto 0; line-height: 1.45; }
</style>
