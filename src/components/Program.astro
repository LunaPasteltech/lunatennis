---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).program;
---
<section class="prog pad" id="program">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
    </div>

    <div class="days">
      {c.days.map((d) => (
        <article class="day reveal">
          <div class="head"><span class="num">{d.n}</span><h3>{d.title}</h3></div>
          <p class="dtext">{d.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .prog { position: relative; background: linear-gradient(160deg, #262320 0%, var(--ink) 60%, #322d26 100%); color: var(--ivory); }
  .prog::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 110px; background: linear-gradient(180deg, var(--ivory), transparent); opacity: .1; pointer-events: none; }
  .prog::after { content: ''; position: absolute; inset: 0; box-shadow: inset 0 0 140px rgba(10,8,6,.45); pointer-events: none; }
  .prog .wrap { position: relative; z-index: 1; }
  .prog .eyebrow { color: var(--terracotta-soft); }
  .prog h2 { color: var(--ivory); }
  .days { margin-top: 44px; }
  .day { display: grid; grid-template-columns: 240px 1fr; gap: 30px; padding: clamp(28px, 4vw, 46px) 0; border-top: 1px solid rgba(251,248,241,.16); }
  .day:last-child { border-bottom: 1px solid rgba(251,248,241,.16); }
  @media (max-width: 760px) { .day { grid-template-columns: 1fr; gap: 14px; } }
  .head .num { font-family: var(--serif); font-size: clamp(2.4rem, 5vw, 3.6rem); color: var(--terracotta-soft); line-height: .9; }
  .head h3 { color: var(--ivory); margin-top: 8px; font-size: 1.5rem; }
  .dtext { font-family: var(--serif); font-size: clamp(1.15rem, 2vw, 1.5rem); color: rgba(251,248,241,.94); font-weight: 300; line-height: 1.65; max-width: 56ch; align-self: center; }
</style>
