---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).program;
---
<section class="prog pad" id="program">
  <div class="wrap">
    <div class="center">
      <p class="eyebrow reveal">{c.eyebrow}</p>
      <div class="rule reveal"></div>
      <h2 class="reveal">{c.title}</h2>
      <p class="accent reveal">{c.accent}</p>
    </div>

    <div class="days">
      {c.days.map((d) => (
        <article class="day reveal">
          <div class="head">
            <span class="num">{d.n}</span>
            <div class="tline">
              <svg class="racket" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <ellipse cx="9.5" cy="8.5" rx="6" ry="7"/>
                <line x1="6.7" y1="13.4" x2="3.6" y2="20.5"/>
                <line x1="4.8" y1="6.6" x2="14" y2="10"/>
                <line x1="6" y1="4.4" x2="12.8" y2="13"/>
              </svg>
              <h3>{d.title}</h3>
            </div>
          </div>
          <p class="dtext">{d.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .prog { background: var(--paper); }
  .accent {
    margin-top: 20px;
    font-family: var(--serif); font-style: italic;
    font-size: clamp(1.05rem, 1.7vw, 1.3rem);
    color: var(--terracotta);
  }
  .days { margin-top: clamp(44px, 6vw, 64px); }
  .day {
    display: grid; grid-template-columns: 250px 1fr; gap: clamp(24px, 4vw, 48px);
    padding: clamp(34px, 5vw, 52px) 0;
    border-top: 1px solid var(--line);
    align-items: center;
  }
  .day:last-child { border-bottom: 1px solid var(--line); }
  @media (max-width: 760px) { .day { grid-template-columns: 1fr; gap: 14px; } }
  .num { font-family: var(--serif); font-size: clamp(2.4rem, 5vw, 3.6rem); color: var(--sand-deep); line-height: .9; display: block; }
  .tline { display: flex; align-items: center; gap: 10px; margin-top: 10px; }
  .racket { width: 17px; height: 17px; color: var(--terracotta); flex: none; opacity: .85; }
  .tline h3 { font-size: clamp(1.4rem, 2.4vw, 1.8rem); color: var(--ink); }
  .dtext {
    font-family: var(--serif); font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    color: var(--ink-soft); font-weight: 300; line-height: 1.7; max-width: 56ch;
  }
</style>
