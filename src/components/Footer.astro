---
import { t, type Locale } from '../i18n/content';
const { locale } = Astro.props as { locale: Locale };
const c = t(locale).footer;
const year = 2026;
---
<footer class="footer">
  <div class="wrap center">
    <svg class="fmark" viewBox="0 0 32 32" aria-hidden="true">
      <circle cx="16" cy="16" r="15" fill="#B5613A"/>
      <g fill="none" stroke="#FBF8F1" stroke-width="2" stroke-linecap="round" opacity="0.92">
        <path d="M5.5 5.5 C 12 11, 12 21, 5.5 26.5"/>
        <path d="M26.5 5.5 C 20 11, 20 21, 26.5 26.5"/>
      </g>
    </svg>
    <div class="brand">Luna</div>
    <p class="tag">{c.tagline}</p>
    {false && <div class="links">
      <a href="https://instagram.com" target="_blank" rel="noopener">Instagram</a>
      <a href="https://t.me/REPLACE" target="_blank" rel="noopener">Telegram</a>
    </div>}
    <p class="copy">© {year} {c.rights}</p>
  </div>
</footer>

<style>
  .footer { background: var(--ink); color: rgba(251,248,241,.6); padding: 56px 20px; }
  .fmark { width: 36px; height: 36px; margin: 0 auto 14px; display: block; }
  .brand { font-family: var(--serif); font-size: 1.5rem; letter-spacing: .16em; color: rgba(251,248,241,.92); }
  .tag { color: rgba(251,248,241,.7); font-size: .78rem; letter-spacing: .16em; text-transform: uppercase; margin-top: 12px; }
  .links { display: flex; justify-content: center; gap: 20px; margin-top: 18px; }
  .links a { font-size: .72rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(251,248,241,.75); }
  .links a:hover { color: var(--ivory); }
  .copy { font-size: .68rem; letter-spacing: .14em; text-transform: uppercase; margin-top: 20px; opacity: .6; }
</style>
