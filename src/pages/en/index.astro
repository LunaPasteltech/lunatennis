---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Audience from '../../components/Audience.astro';
import Concept from '../../components/Concept.astro';
import Experience from '../../components/Experience.astro';
import Mentors from '../../components/Mentors.astro';
import Program from '../../components/Program.astro';
import Reviews from '../../components/Reviews.astro';
import Pricing from '../../components/Pricing.astro';
import Gallery from '../../components/Gallery.astro';
import Faq from '../../components/Faq.astro';
import Apply from '../../components/Apply.astro';
import Footer from '../../components/Footer.astro';
const locale = 'en' as const;
---
<Base locale={locale}>
  <Nav locale={locale} />
  <Hero locale={locale} />
  <Concept locale={locale} />
  <Audience locale={locale} />
  <Experience locale={locale} />
  <Mentors locale={locale} />
  <Program locale={locale} />
  <Reviews locale={locale} />
  <Pricing locale={locale} />
  <Gallery locale={locale} />
  <Faq locale={locale} />
  <Apply locale={locale} />
  <Footer locale={locale} />
</Base>
